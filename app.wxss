page {
  --primary: #07c160;
  --primary-light: #e8f8ee;
  --text: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --bg: #f5f5f5;
  --card: #ffffff;
  --border: #eeeeee;
  background-color: var(--bg);
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}
.card {
  background: var(--card);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  width: 100%;
}
.btn-primary:active { opacity: 0.8; }
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}
.loading-text { color: var(--text-light); font-size: 28rpx; margin-top: 20rpx; }
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 0;
}
.empty-icon { font-size: 120rpx; margin-bottom: 30rpx; }
.empty-text { color: var(--text-light); font-size: 30rpx; }
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
