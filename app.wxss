/* 每日早报 — 全局样式 v2 (Anti-Slop) */
page {
  --primary: #1c1c1e;
  --primary-light: #f5f5f7;
  --bg: #f5f5f7;
  --card: #ffffff;
  --text: #1c1c1e;
  --text-secondary: #6a6a6a;
  --text-light: #a0a0a0;
  --radius: 14px;
  --radius-sm: 10px;
  --safe-bottom: env(safe-area-inset-bottom, 0px);
  background-color: var(--bg);
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}
view, text, image, button, input { box-sizing: border-box; }
.card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 28rpx;
  margin: 6rpx 20rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.02), 0 0 0 1rpx rgba(0,0,0,0.02);
}
.card:active { opacity: 0.9; transform: scale(0.98); }
.btn {
  background: var(--primary);
  color: #fff;
  border-radius: var(--radius-sm);
  padding: 22rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  width: 100%;
  transition: opacity .2s;
}
.btn:active { opacity: .85; }
.btn[disabled] { background: #c0c0c0; }
.tag {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 600;
  color: var(--text-light);
  background: rgba(0,0,0,0.04);
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}
.empty-box {
  display: flex; flex-direction: column; align-items: center;
  padding: 180rpx 60rpx;
}
.empty-icon { width: 120rpx; height: 120rpx; background: #f0efeb; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 56rpx; margin-bottom: 28rpx; }
.empty-title { font-size: 32rpx; font-weight: 600; color: var(--text); margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: var(--text-light); text-align: center; line-height: 1.8; margin-bottom: 48rpx; }
.loading-box { display: flex; flex-direction: column; align-items: center; padding: 200rpx 0; }
.loading-text { color: var(--text-light); font-size: 26rpx; margin-top: 20rpx; }
.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
