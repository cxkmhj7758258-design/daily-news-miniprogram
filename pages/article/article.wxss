.ap { padding: 28rpx; }
.ap__cat {
  display: inline-block;
  font-size: 22rpx; font-weight: 600;
  color: var(--text-light); background: rgba(0,0,0,0.04);
  padding: 6rpx 18rpx; border-radius: 6rpx; margin-bottom: 20rpx;
}
.ap__title { font-size: 44rpx; font-weight: 700; color: var(--text); line-height: 1.4; margin-bottom: 16rpx; letter-spacing: -1rpx; }
.ap__meta { font-size: 24rpx; color: var(--text-light); margin-bottom: 32rpx; padding-bottom: 24rpx; border-bottom: 1rpx solid rgba(0,0,0,0.04); }
.ap__body { font-size: 30rpx; color: var(--text-secondary); line-height: 2; }
.ap__ft { display: flex; margin-top: 60rpx; padding-top: 28rpx; border-top: 1rpx solid rgba(0,0,0,0.04); }
