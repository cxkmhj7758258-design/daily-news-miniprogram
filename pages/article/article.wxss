.page { padding: 30rpx; }
.article-header {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.article-category {
  display: inline-block;
  font-size: 24rpx;
  color: #07c160;
  background: #e8f8ee;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}
.article-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.5;
  margin-bottom: 20rpx;
}
.article-meta {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #999;
}
.article-body {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  min-height: 400rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.article-content {
  font-size: 32rpx;
  color: #444;
  line-height: 1.9;
}
.article-footer {
  display: flex;
  gap: 20rpx;
  padding: 40rpx 0;
}
.article-footer button { flex: 1; }
.share-btn { margin: 0; }
