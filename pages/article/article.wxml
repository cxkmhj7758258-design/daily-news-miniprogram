<view class="ap">
  <view class="ap__cat">{{cat}}</view>
  <view class="ap__title">{{title}}</view>
  <view class="ap__meta">{{source}} · {{time}}</view>
  <view class="ap__body">
    <text>{{summary}}</text>
  </view>
  <view class="ap__ft">
    <button class="btn" style="flex:1" bind:tap="back">← 返回</button>
    <button class="btn" style="flex:1;background:#f0efeb;color:var(--text);margin-left:16rpx" bind:tap="onShare">分享 ↗</button>
  </view>
</view>
