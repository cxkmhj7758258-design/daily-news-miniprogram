<view class="page">
  <!-- 顶部 -->
  <view class="hd">
    <view class="hd__date">{{dateStr}}</view>
    <view class="hd__greeting">☀️ 早上好</view>
    <view class="hd__sub">今日早报已准备好</view>
  </view>

  <!-- 加载 -->
  <view wx:if="{{loading}}" class="loading-box">
    <loading />
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态：未选领域 -->
  <view wx:elif="{{!hasCats}}" class="empty-box">
    <view class="empty-icon">📰</view>
    <view class="empty-title">还没有关注领域</view>
    <view class="empty-desc">去设置中选择你感兴趣的领域</view>
    <button class="btn" style="width:300rpx" bind:tap="goSettings">去设置</button>
  </view>

  <!-- 新闻列表 -->
  <view wx:else class="nl">
    <view
      wx:for="{{groups}}"
      wx:for-item="g"
      wx:key="cat"
      class="ng"
    >
      <view class="ng__hd">
        <text class="ng__icon">{{g.icon}}</text>
        <text class="ng__name">{{g.name}}</text>
        <text class="ng__cnt">{{g.list.length}}条</text>
      </view>
      <view
        wx:for="{{g.list}}"
        wx:for-item="item"
        wx:key="id"
        class="card"
        bind:tap="onTap"
        data-cat="{{g.cat}}"
        data-title="{{item.title}}"
      >
        <view class="tag">{{g.name}}</view>
        <view class="card__title">{{item.title}}</view>
        <view class="card__summary">{{item.summary}}</view>
        <view class="card__ft">
          <text>{{item.source}}</text>
          <text>{{item.time}}</text>
        </view>
      </view>
    </view>
    <view class="nl__foot">— 明早见 —</view>
  </view>
</view>
