.page { min-height: 100vh; }
.hd {
  padding: 32rpx 28rpx 36rpx;
  position: relative;
  background: #faf9f6;
}
.hd::after {
  content: '';
  position: absolute;
  top: -80rpx; right: -60rpx;
  width: 300rpx; height: 300rpx;
  background: radial-gradient(circle, rgba(200,190,175,0.2) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}
.hd__date {
  font-size: 24rpx;
  color: var(--text-light);
  font-weight: 500;
  letter-spacing: 1rpx;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}
.hd__greeting {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -1rpx;
  line-height: 1.1;
  margin-bottom: 8rpx;
  position: relative;
  z-index: 1;
}
.hd__sub {
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
  z-index: 1;
}
.ng { margin-bottom: 10rpx; }
.ng__hd {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx 12rpx;
}
.ng__icon { font-size: 28rpx; margin-right: 10rpx; }
.ng__name { font-size: 30rpx; font-weight: 600; color: var(--text); }
.ng__cnt {
  margin-left: auto;
  font-size: 22rpx;
  color: var(--text-light);
  background: rgba(0,0,0,0.03);
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}
.card__title {
  font-size: 32rpx;
  font-weight: 650;
  color: var(--text);
  line-height: 1.45;
  margin: 10rpx 0 8rpx;
  letter-spacing: -0.5rpx;
}
.card__summary {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 14rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.card__ft {
  display: flex;
  justify-content: space-between;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(0,0,0,0.04);
  font-size: 22rpx;
  color: var(--text-light);
}
.nl__foot {
  text-align: center;
  padding: 50rpx 0 60rpx;
  font-size: 24rpx;
  color: #ccc;
}
