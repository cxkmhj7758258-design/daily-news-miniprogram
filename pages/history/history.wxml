<view class="mp">
  <view class="mp__hd">
    <view class="mp__av">早</view>
    <view class="mp__info">
      <text class="mp__name">每日早报</text>
      <text class="mp__desc">已读 {{readCnt}} 篇</text>
    </view>
  </view>

  <view class="mp__stats">
    <view class="ms">
      <text class="ms__num">{{catCnt}}</text>
      <text class="ms__label">关注</text>
    </view>
    <view class="ms">
      <text class="ms__num">{{todayCnt}}</text>
      <text class="ms__label">今日</text>
    </view>
    <view class="ms">
      <text class="ms__num">{{readCnt}}</text>
      <text class="ms__label">已读</text>
    </view>
  </view>

  <view class="mp__menu">
    <view class="mi" bind:tap="goSettings">
      <text class="mi__icon">⚙️</text>
      <text class="mi__label">关注设置</text>
      <text class="mi__arrow">›</text>
    </view>
    <view class="mi" bind:tap="onClear">
      <text class="mi__icon">🗑️</text>
      <text class="mi__label">清除缓存</text>
      <text class="mi__arrow">›</text>
    </view>
    <view class="mi" bind:tap="onAbout">
      <text class="mi__icon">ℹ️</text>
      <text class="mi__label">关于</text>
      <text class="mi__arrow">›</text>
    </view>
  </view>
</view>
