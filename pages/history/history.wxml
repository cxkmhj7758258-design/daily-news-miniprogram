<view class="page">
  <!-- 用户头像区域 -->
  <view class="user-card">
    <view class="avatar">{{initials}}</view>
    <view class="user-info">
      <text class="user-name">每日早报用户</text>
      <text class="user-desc">已读 {{readCount}} 篇新闻</text>
    </view>
  </view>

  <!-- 数据概览 -->
  <view class="stats-grid">
    <view class="stat-item">
      <text class="stat-num">{{selectedCount}}</text>
      <text class="stat-label">关注领域</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{todayCount}}</text>
      <text class="stat-label">今日新闻</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{readCount}}</text>
      <text class="stat-label">已读</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goSettings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-label">关注设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="clearCache">
      <text class="menu-icon">🗑️</text>
      <text class="menu-label">清除缓存</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="feedback">
      <text class="menu-icon">💬</text>
      <text class="menu-label">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="about">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-label">关于</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
