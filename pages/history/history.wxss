.page { padding-bottom: 40rpx; }
.user-card {
  background: linear-gradient(135deg, #07c160, #06ad56);
  margin: 30rpx;
  padding: 40rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  color: #fff;
}
.avatar {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  margin-right: 24rpx;
}
.user-info { flex: 1; }
.user-name { font-size: 36rpx; font-weight: 600; display: block; margin-bottom: 6rpx; }
.user-desc { font-size: 26rpx; opacity: 0.85; }
.stats-grid {
  display: flex;
  margin: 0 30rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.stat-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #f0f0f0;
}
.stat-item:last-child { border: none; }
.stat-num { font-size: 44rpx; font-weight: 700; color: #07c160; display: block; }
.stat-label { font-size: 24rpx; color: #999; margin-top: 6rpx; display: block; }
.menu-section {
  background: #fff;
  margin: 0 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.menu-item:last-child { border: none; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-label { flex: 1; font-size: 30rpx; color: #333; }
.menu-arrow { font-size: 32rpx; color: #ccc; }
