<view class="sp">
  <view class="sp__hd">
    <text class="sp__title">关注领域</text>
    <text class="sp__desc">选择你感兴趣的领域，每日精选推送</text>
  </view>

  <view class="grid">
    <view
      wx:for="{{cats}}" wx:key="id"
      class="gi {{item.sel ? 'gi--sel' : ''}}"
      bind:tap="tog"
      data-id="{{item.id}}"
    >
      <text class="gi__icon">{{item.icon}}</text>
      <text class="gi__name">{{item.name}}</text>
      <view wx:if="{{item.sel}}" class="gi__check">✓</view>
    </view>
  </view>

  <view class="cinfo">
    已选 <text class="cinfo__num">{{cnt}}</text> 个
    <text wx:if="{{cnt < 3}}" class="cinfo__hint">（至少选3个）</text>
  </view>

  <view class="sec">
    <view class="sec__title">推送设置</view>
    <view class="sr">
      <view>
        <text class="sr__label">每日推送</text>
        <text class="sr__desc">每天早上推送精选早报</text>
      </view>
      <switch checked="{{push}}" color="#1c1c1e" bindchange="togPush" />
    </view>
    <view class="sr" wx:if="{{push}}">
      <view>
        <text class="sr__label">推送时间</text>
        <text class="sr__desc">选择接收时间</text>
      </view>
      <picker mode="time" value="{{ptime}}" bindchange="onTime">
        <view class="tp">{{ptime}}</view>
      </picker>
    </view>
  </view>

  <view class="sbar">
    <button class="btn {{cnt < 3 ? 'btn--ds' : ''}}" disabled="{{cnt < 3}}" bind:tap="save">保存</button>
  </view>
</view>
