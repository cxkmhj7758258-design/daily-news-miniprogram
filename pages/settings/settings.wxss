.page-container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}
.page-header {
  padding: 40rpx 40rpx 20rpx;
}
.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}
.page-desc {
  font-size: 28rpx;
  color: #999;
  line-height: 1.6;
}
.categories-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 30rpx;
  gap: 20rpx;
}
.category-item {
  width: calc(33.33% - 14rpx);
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  border: 2rpx solid #eee;
  transition: all 0.2s;
}
.category-item.selected {
  border-color: #07c160;
  background: #f0fff4;
}
.category-icon { font-size: 52rpx; margin-bottom: 12rpx; }
.category-name { font-size: 28rpx; color: #333; font-weight: 500; }
.check-mark {
  position: absolute;
  top: 10rpx;
  right: 14rpx;
  width: 32rpx;
  height: 32rpx;
  background: #07c160;
  color: #fff;
  border-radius: 50%;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.count-info {
  text-align: center;
  padding: 20rpx;
}
.count-text { font-size: 28rpx; color: #666; }
.count-num { color: #07c160; font-weight: 700; font-size: 36rpx; }
.count-hint { font-size: 26rpx; color: #ff6b6b; }
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx 40rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}
.save-btn.disabled { background: #ccc; }
.section {
  margin: 30rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}
.section-title { font-size: 32rpx; font-weight: 600; margin-bottom: 20rpx; }
.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
}
.setting-row:first-child { border-top: none; }
.setting-label { font-size: 30rpx; color: #333; display: block; }
.setting-desc { font-size: 24rpx; color: #999; display: block; margin-top: 4rpx; }
.time-picker {
  background: #f5f5f5;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
}
.save-success {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0,0,0,0.8);
  color: #fff;
  padding: 40rpx 60rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 100;
}
.success-icon {
  width: 80rpx;
  height: 80rpx;
  background: #07c160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 20rpx;
}
.success-text { font-size: 30rpx; text-align: center; }
