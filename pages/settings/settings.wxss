.sp { min-height: 100vh; padding-bottom: 160rpx; }
.sp__hd { padding: 28rpx 28rpx 12rpx; }
.sp__title { font-size: 40rpx; font-weight: 700; color: var(--text); display: block; margin-bottom: 8rpx; letter-spacing: -0.5rpx; }
.sp__desc { font-size: 26rpx; color: var(--text-light); line-height: 1.6; }
.grid { display: flex; flex-wrap: wrap; padding: 8rpx 16rpx; gap: 14rpx; }
.gi {
  width: calc(33.33% - 10rpx);
  background: var(--card);
  border-radius: var(--radius-sm);
  padding: 28rpx 8rpx 22rpx;
  display: flex; flex-direction: column; align-items: center;
  border: 2rpx solid rgba(0,0,0,0.06);
  transition: all 0.2s;
  position: relative;
}
.gi:active { opacity: 0.8; }
.gi--sel { border-color: var(--primary); background: #faf9f6; }
.gi__icon { font-size: 48rpx; margin-bottom: 10rpx; }
.gi__name { font-size: 24rpx; color: var(--text); font-weight: 500; }
.gi__check {
  position: absolute; top: 8rpx; right: 8rpx;
  width: 32rpx; height: 32rpx;
  background: var(--primary); color: #fff;
  border-radius: 50%; font-size: 20rpx;
  display: flex; align-items: center; justify-content: center;
}
.cinfo { text-align: center; padding: 20rpx; font-size: 26rpx; color: var(--text-secondary); }
.cinfo__num { font-weight: 650; font-size: 34rpx; color: var(--text); }
.cinfo__hint { color: #d44; font-size: 24rpx; font-weight: 500; }
.sec {
  background: var(--card); margin: 16rpx 24rpx;
  border-radius: var(--radius); padding: 28rpx;
}
.sec__title { font-size: 30rpx; font-weight: 600; color: var(--text); margin-bottom: 20rpx; }
.sr {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 0; border-top: 1rpx solid rgba(0,0,0,0.04);
}
.sr:first-child { border-top: none; }
.sr__label { font-size: 28rpx; color: var(--text); font-weight: 500; display: block; }
.sr__desc { font-size: 24rpx; color: var(--text-light); display: block; margin-top: 4rpx; }
.tp {
  background: rgba(0,0,0,0.04); padding: 12rpx 24rpx;
  border-radius: var(--radius-sm); font-size: 28rpx;
  font-weight: 600; color: var(--text);
}
.sbar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 16rpx 28rpx 40rpx;
  background: linear-gradient(transparent, var(--bg) 30%);
}
.btn--ds { background: #c0c0c0; }
