.news-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 16rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  transition: transform 0.2s;
}
.news-card:active { transform: scale(0.98); }
.card-category {
  display: inline-block;
  font-size: 22rpx;
  color: #07c160;
  background: #e8f8ee;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}
.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.5;
  margin-bottom: 12rpx;
}
.card-summary {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.card-source { font-size: 24rpx; color: #999; }
.card-time { font-size: 24rpx; color: #bbb; }
